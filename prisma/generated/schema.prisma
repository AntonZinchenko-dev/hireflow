generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String        @id @default(cuid())
  name        String
  email       String        @unique
  role        String        @default("recruiter") // recruiter | hiring_manager | admin
  isBot       Boolean       @default(false)
  createdAt   DateTime      @default(now())
  candidates  Candidate[]   @relation("AssignedRecruiter")
  interviews  Interview[]
  comments    Comment[]
  activityLog ActivityLog[]
}

model PortalProfile {
  id           String      @id @default(cuid())
  authUserId   String      @unique
  email        String
  fullName     String
  role         String      @default("candidate") // employer | candidate
  headline     String?
  bio          String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  applications Candidate[]
}

model Vacancy {
  id         String      @id @default(cuid())
  title      String
  grade      String
  department String
  status     String      @default("open") // open | closed
  createdAt  DateTime    @default(now())
  stages     Stage[]
  candidates Candidate[]
}

model Stage {
  id         String      @id @default(cuid())
  vacancyId  String
  vacancy    Vacancy     @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  name       String
  order      Int
  candidates Candidate[]

  @@index([vacancyId])
}

model Candidate {
  id                    String         @id @default(cuid())
  vacancyId             String
  vacancy               Vacancy        @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  stageId               String
  stage                 Stage          @relation(fields: [stageId], references: [id])
  fullName              String
  source                String // site | referral | agency | headhunting
  referrerName          String?
  grade                 String // junior | middle | senior | lead
  seniorityExpectations String?
  expectedSalary        Float
  offerAmount           Float?
  offerDeadline         DateTime?
  resumeUrl             String?
  assignedRecruiterId   String
  assignedRecruiter     User           @relation("AssignedRecruiter", fields: [assignedRecruiterId], references: [id])
  portalProfileId       String?
  portalProfile         PortalProfile? @relation(fields: [portalProfileId], references: [id], onDelete: SetNull)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  interviews            Interview[]
  comments              Comment[]
  activity              ActivityLog[]

  @@unique([vacancyId, portalProfileId])
  @@index([vacancyId])
  @@index([stageId])
  @@index([portalProfileId])
}

model Interview {
  id            String    @id @default(cuid())
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviewerId String
  interviewer   User      @relation(fields: [interviewerId], references: [id])
  scoreTech     Int
  scoreComm     Int
  scoreCulture  Int
  verdict       String // hire | no_hire | lean_hire | lean_no_hire
  comment       String?
  createdAt     DateTime  @default(now())
  criteria      Json? // [{ name: string, score: number }]

  @@index([candidateId])
}

model Comment {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  text        String
  createdAt   DateTime  @default(now())

  @@index([candidateId])
}

model ActivityLog {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User      @relation(fields: [actorId], references: [id])
  type        String // created | stage_moved | field_changed | comment_added | interview_added
  payload     Json
  createdAt   DateTime  @default(now())

  @@index([candidateId])
}
